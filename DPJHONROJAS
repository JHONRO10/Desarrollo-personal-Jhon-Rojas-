            </div>
            <Bar pct={pct} color={g.color} height={6} />
          </div>
        );
      })}

      {/* Observer model card */}
      <div style={{
        background:`linear-gradient(135deg, ${C.gold}12, ${C.crimson}08)`,
        border:`1px solid ${C.gold}30`, borderRadius:18, padding:18, marginTop:8,
      }}>
        <div style={{ fontSize:10, letterSpacing:2, color:C.gold, textTransform:"uppercase", marginBottom:10 }}>
          Tu framework
        </div>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:12 }}>
          {["Observador","→","Acción","→","Resultado"].map((item,i) => (
            <div key={i} style={{
              fontSize: item==="→" ? 16 : 12,
              fontWeight: item==="→" ? 400 : 700,
              color: item==="→" ? C.muted : C.text,
              textAlign:"center",
            }}>{item}</div>
          ))}
        </div>
        <div style={{ fontSize:13, color:C.muted, fontStyle:"italic", lineHeight:1.6 }}>
          "Del observador que eres, al líder que puedes ser."
        </div>
      </div>

      {/* 36-month vision */}
      <div style={{ background:C.surface, border:`1px solid ${C.border}`, borderRadius:16, padding:16, marginTop:12 }}>
        <div style={{ fontSize:10, letterSpacing:2, color:C.crimson, textTransform:"uppercase", marginBottom:12 }}>
          Roadmap 36 meses
        </div>
        {[
          { yr:"Año 1", desc:"Lanzar SaaS + primer programa de transformación", active:true },
          { yr:"Año 2", desc:"Escalar programas grupales y eventos en LATAM", active:false },
          { yr:"Año 3", desc:"Certificación de facilitadores + presencia panregional", active:false },
        ].map((item,i) => (
          <div key={i} style={{ display:"flex", gap:12, marginBottom: i<2 ? 12 : 0 }}>
            <div style={{ display:"flex", flexDirection:"column", alignItems:"center" }}>
              <div style={{ width:10, height:10, borderRadius:"50%", background: item.active ? C.gold : C.dim, marginTop:3 }} />
              {i < 2 && <div style={{ width:1, height:28, background:C.border, margin:"3px 0" }} />}
            </div>
            <div>
              <div style={{ fontSize:12, fontWeight:700, color: item.active ? C.gold : C.muted }}>{item.yr}</div>
              <div style={{ fontSize:12, color:C.muted, lineHeight:1.5 }}>{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

