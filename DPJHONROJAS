const toMins = (t) => { const [h,m] = t.split(":").map(Number); return h*60+m; };
const getActive = (now) => {
  const tm = now.getHours()*60 + now.getMinutes();
  return BLOCKS.find(b => tm >= toMins(b.start) && tm < toMins(b.end)) || null;
};
const fmtTime = (d) => d.toLocaleTimeString("es-CO",{hour:"2-digit",minute:"2-digit"});
const fmtDate = (d) => d.toLocaleDateString("es-CO",{weekday:"long",day:"numeric",month:"long"});
const capitalize = (s) => s.charAt(0).toUpperCase() + s.slice(1);

