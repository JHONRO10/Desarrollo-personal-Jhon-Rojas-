function SaasView({ completedSteps, onToggle }) {
  const pct = Math.round((completedSteps.length / STEPS.length) * 100);
  const nextIdx = STEPS.findIndex((_, i) => !completedSteps.includes(i));
  const [filter, setFilter] = useState("all"); // all | pending | done

  const filtered = STEPS.map((s,i) => ({s,i})).filter(({i}) => {
    if (filter === "done") return completedSteps.includes(i);
    if (filter === "pending") return !completedSteps.includes(i);
    return true;
  });

  return (
    <div style={{ padding:"20px 16px" }}>
      <SectionHeader label="Proyecto principal" title="SaaS de Perfumería" />

      {/* Big progress card */}
      <div style={{
        background:`linear-gradient(135deg, ${C.crimson}15, ${C.gold}08)`,
        border:`1px solid ${C.crimson}33`, borderRadius:18, padding:18, marginBottom:16,
        display:"flex", alignItems:"center", gap:16,
      }}>
        <Ring pct={pct} size={86} stroke={7} color={C.crimson}>
          <span style={{ fontSize:18, fontWeight:900, color:C.crimson }}>{pct}%</span>
        </Ring>
        <div>
          <div style={{ fontSize:30, fontWeight:900, color:C.text, lineHeight:1 }}>
            {completedSteps.length}<span style={{ fontSize:16, color:C.muted }}>/{STEPS.length}</span>
          </div>
          <div style={{ fontSize:12, color:C.muted, marginTop:2 }}>pasos completados</div>
          {nextIdx >= 0 && (
            <div style={{ fontSize:11, color:C.gold, marginTop:6, fontWeight:600 }}>
              → Paso {nextIdx+1}: {STEPS[nextIdx].slice(0,30)}...
            </div>
          )}
        </div>
      </div>
      <Bar pct={pct} color={`linear-gradient(90deg,${C.crimson},${C.gold})`} height={5} />

      {/* Filter tabs */}
      <div style={{ display:"flex", gap:6, marginTop:18, marginBottom:14 }}>
        {[["all","Todos"],["pending","Pendientes"],["done","✓ Listos"]].map(([v,l]) => (
          <button key={v} onClick={() => setFilter(v)} style={{
            flex:1, padding:"8px 4px", borderRadius:10, border:`1px solid ${filter===v ? C.gold+"55" : C.border}`,
            background: filter===v ? `${C.gold}15` : C.surface,
            color: filter===v ? C.gold : C.muted, fontSize:11, fontWeight:700,
            cursor:"pointer", transition:"all 0.2s",
          }}>{l}</button>
        ))}
      </div>

      {/* Steps */}
      {filtered.map(({s,i}) => {
        const done = completedSteps.includes(i);
        const isNext = i === nextIdx;
        return (
          <div key={i} style={{
            background: done ? `${C.green}0d` : isNext ? `${C.gold}0a` : C.surface,
            border:`1px solid ${done ? C.green+"2a" : isNext ? C.gold+"44" : C.border}`,
            borderRadius:12, padding:"11px 13px", marginBottom:6,
            display:"flex", alignItems:"center", gap:11,
          }}>
            <div style={{
              width:28, height:28, borderRadius:"50%", flexShrink:0,
              background: done ? C.green : isNext ? C.goldDim : C.dim,
              display:"flex", alignItems:"center", justifyContent:"center",
              fontSize:11, fontWeight:900,
              color: done ? "#000" : isNext ? C.gold : C.muted,
            }}>
              {done ? "✓" : i+1}
            </div>
            <div style={{ flex:1, fontSize:13, color: done ? C.muted : C.text,
              textDecoration: done ? "line-through" : "none",
              fontWeight: isNext ? 700 : 400 }}>
              {s}
            </div>
            <button onClick={() => onToggle(i)} style={{
              background:"none", border:"none", cursor:"pointer",
              fontSize:18, color: done ? C.green : C.muted, padding:"0 4px",
            }}>
              {done ? "✓" : "○"}
            </button>
          </div>
        );
      })}
    </div>
  );
}

