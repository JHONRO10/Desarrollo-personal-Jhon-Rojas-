          Tu misión
        </div>
        <div style={{ fontSize:13, color:C.text, lineHeight:1.75 }}>
          Construir un SaaS de perfumería funcional y vendible que genere libertad financiera y permita escalar el impacto del coaching ontológico en LATAM, España y EE.UU.
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════
//  MAIN APP
// ═══════════════════════════════════════════════

const TABS = [
  { id:"dashboard", icon:"⌂",  label:"Inicio"  },
  { id:"day",       icon:"◎",  label:"Día"     },
  { id:"saas",      icon:"◈",  label:"SaaS"    },
  { id:"goals",     icon:"◇",  label:"Metas"   },
  { id:"energy",    icon:"✦",  label:"Energía" },
];

export default function FounderMissionOS() {
  const todayStr = new Date().toDateString();

  const [completedBlocks, setCompletedBlocks] = useState(() => {
    try { const d = JSON.parse(localStorage.getItem("fmos_d")||"{}"); return d.date===todayStr ? d.b||[] : []; }
    catch { return []; }
  });

  const [completedSteps, setCompletedSteps] = useState(() => {
    try { return JSON.parse(localStorage.getItem("fmos_s")||"[]"); }
    catch { return []; }
  });

  const [view, setView]   = useState("dashboard");
  const [toast, setToast] = useState(null);
  const [now, setNow]     = useState(new Date());

  useEffect(() => {
    localStorage.setItem("fmos_d", JSON.stringify({ date:todayStr, b:completedBlocks }));
  }, [completedBlocks, todayStr]);

  useEffect(() => {
    localStorage.setItem("fmos_s", JSON.stringify(completedSteps));
  }, [completedSteps]);

  useEffect(() => {
    const t = setInterval(() => setNow(new Date()), 30000);
    return () => clearInterval(t);
  }, []);

  const activeBlock = getActive(now);

  const toggleBlock = (id) => {
    setCompletedBlocks(prev => {
      if (prev.includes(id)) return prev.filter(x => x !== id);
      setToast("Cada tarea completada te acerca a crear tu empresa tecnológica.");
      return [...prev, id];
    });
  };

  const toggleStep = (i) => {
    setCompletedSteps(prev => {
      if (prev.includes(i)) return prev.filter(x => x !== i);
      setToast("Estás un paso más cerca de lanzar tu aplicación.");
      return [...prev, i];
    });
  };

  const points = completedBlocks.reduce((s,id) => s + (BLOCKS.find(b=>b.id===id)?.pts||0), 0);

  return (
    <>
      <style>{`
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { background: ${C.bg}; color: ${C.text}; font-family: -apple-system, 'SF Pro Display', 'Helvetica Neue', system-ui, sans-serif; overflow-x: hidden; }
        ::-webkit-scrollbar { width: 3px; }
        ::-webkit-scrollbar-thumb { background: ${C.dim}; border-radius: 2px; }
        button { -webkit-tap-highlight-color: transparent; }
        @keyframes fid { from { opacity:0; transform:translateX(-50%) translateY(-12px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }
      `}</style>

      <div style={{ background:C.bg, minHeight:"100vh", maxWidth:440, margin:"0 auto", position:"relative" }}>

        {/* ── Top bar ── */}
        <div style={{
          position:"sticky", top:0, zIndex:200,
          background:`${C.bg}ee`, backdropFilter:"blur(20px)",
          borderBottom:`1px solid ${C.border}`,
          padding:"11px 16px", display:"flex", alignItems:"center", justifyContent:"space-between",
        }}>
          <div style={{ display:"flex", alignItems:"center", gap:8 }}>
            <div style={{ width:7, height:7, borderRadius:"50%", background:C.gold }} />
            <span style={{ fontSize:13, fontWeight:900, letterSpacing:1, color:C.text }}>FOUNDER MISSION OS</span>
          </div>
          <div style={{ fontSize:13, fontWeight:700, color:C.gold, letterSpacing:0.5 }}>
            {fmtTime(now)}
          </div>
        </div>

        {/* ── Daily progress strip ── */}
        <div style={{ height:3, background:C.dim }}>
          <div style={{
            height:"100%",
            width:`${Math.round((completedBlocks.length/BLOCKS.length)*100)}%`,
            background:`linear-gradient(90deg, ${C.gold}, ${C.crimson})`,
            transition:"width 0.6s ease",
          }} />
        </div>

        {/* ── Content ── */}
        <div style={{ paddingBottom:88, minHeight:"calc(100vh - 90px)", overflowY:"auto" }}>
          {view==="dashboard" && <Dashboard completedBlocks={completedBlocks} completedSteps={completedSteps} points={points} now={now} activeBlock={activeBlock} />}
          {view==="day"       && <DayView   completedBlocks={completedBlocks} onToggle={toggleBlock} activeBlock={activeBlock} />}
          {view==="saas"      && <SaasView  completedSteps={completedSteps}   onToggle={toggleStep} />}
          {view==="goals"     && <GoalsView completedSteps={completedSteps}   completedBlocks={completedBlocks} />}
          {view==="energy"    && <EnergyView points={points} completedBlocks={completedBlocks} completedSteps={completedSteps} />}
        </div>

        {/* ── Bottom nav ── */}
        <div style={{
          position:"fixed", bottom:0,
          left:"50%", transform:"translateX(-50%)",
          width:"100%", maxWidth:440,
          background:`${C.bg}f2`, backdropFilter:"blur(24px)",
          borderTop:`1px solid ${C.border}`,
          display:"flex", padding:"8px 0 14px", zIndex:200,
        }}>
          {TABS.map(tab => {
            const active = view === tab.id;
            return (
              <button key={tab.id} onClick={() => setView(tab.id)} style={{
                flex:1, background:"none", border:"none", cursor:"pointer",
                display:"flex", flexDirection:"column", alignItems:"center", gap:3, padding:"5px 0",
                position:"relative",
              }}>
                {active && (
                  <div style={{ position:"absolute", top:0, left:"50%", transform:"translateX(-50%)", width:20, height:2, background:C.gold, borderRadius:1 }} />
                )}
                <div style={{ fontSize:20, color: active ? C.gold : C.muted, transition:"color 0.2s" }}>
                  {tab.icon}
                </div>
                <div style={{ fontSize:9, letterSpacing:0.8, fontWeight:700, textTransform:"uppercase",
                  color: active ? C.gold : C.muted, transition:"color 0.2s" }}>
                  {tab.label}
                </div>
              </button>
            );
          })}
        </div>

        {/* ── Toast ── */}
        {toast && <Toast msg={toast} onDone={() => setToast(null)} />}
      </div>
    </>
  );
}
