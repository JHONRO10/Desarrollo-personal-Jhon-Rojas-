  const dayPct = Math.round((completedBlocks.length / BLOCKS.length) * 100);
  const saasPct = Math.round((completedSteps.length / STEPS.length) * 100);
  const totalPts = BLOCKS.reduce((s,b)=>s+b.pts,0);

  const getAiMotivation = async () => {
    setAiLoading(true);
    setAiMsg("");
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514",
          max_tokens:1000,
          system:`Eres el coach personal de Jhon Rojas, un fundador colombiano que está construyendo un SaaS de perfumería mientras gestiona una academia de coaching ontológico (ADH Coaching Academy). 
Su filosofía se basa en Rafael Echeverría y Joe Dispenza. Su lema es "Del observador que eres, al líder que puedes ser."
Genera un mensaje motivacional MUY personalizado, poderoso y breve (máximo 3 oraciones). Habla directamente a Jhon. Usa español. Sin emojis excesivos.`,
          messages:[{
            role:"user",
            content:`Jhon ha completado ${completedBlocks.length} de ${BLOCKS.length} bloques hoy (${dayPct}%), ${completedSteps.length} de ${STEPS.length} pasos de su SaaS (${saasPct}%) y acumuló ${points} de ${totalPts} puntos. Escribe su mensaje de hoy.`
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.find(c=>c.type==="text")?.text || "Sigue adelante, Jhon.";
      setAiMsg(text);
    } catch {
      setAiMsg("La conexión falló, pero tu misión continúa. Cada bloque completado es una victoria real.");
    }
    setAiLoading(false);
  };

  return (
    <div style={{ padding:"20px 16px" }}>
      <SectionHeader label="Combustible mental" title="Energía del día" />

      {/* Quote card */}
      <div onClick={() => setQIdx(i => (i+1) % QUOTES.length)} style={{
        background:`linear-gradient(135deg, ${C.gold}18, transparent)`,
        border:`1px solid ${C.gold}40`, borderRadius:20, padding:"20px 20px",
        marginBottom:16, cursor:"pointer", position:"relative", overflow:"hidden",
      }}>
        <div style={{ fontSize:48, opacity:0.08, position:"absolute", top:5, right:12, lineHeight:1 }}>❝</div>
        <div style={{ fontSize:15, fontWeight:600, color:C.text, lineHeight:1.7, fontStyle:"italic", marginBottom:10 }}>
          "{QUOTES[qIdx].text}"
        </div>
        {QUOTES[qIdx].by && (
          <div style={{ fontSize:11, color:C.gold }}>— {QUOTES[qIdx].by}</div>
        )}
        <div style={{ fontSize:10, color:C.muted, marginTop:8, letterSpacing:1 }}>TOCA PARA CAMBIAR ↻</div>
      </div>

      {/* AI Motivation */}
      <div style={{ background:C.surface, border:`1px solid ${C.border}`, borderRadius:16, padding:16, marginBottom:16 }}>
        <div style={{ fontSize:10, letterSpacing:2, color:C.muted, textTransform:"uppercase", marginBottom:10 }}>
          ✦ Coach IA personalizado
        </div>
        {aiMsg ? (
          <div style={{ fontSize:14, color:C.text, lineHeight:1.7, marginBottom:12 }}>{aiMsg}</div>
        ) : (
          <div style={{ fontSize:13, color:C.muted, marginBottom:12, lineHeight:1.6 }}>
            Genera un mensaje motivacional basado en tu progreso real de hoy.
          </div>
        )}
        <button onClick={getAiMotivation} disabled={aiLoading} style={{
          width:"100%", padding:"12px", borderRadius:12,
          background: aiLoading ? C.dim : `linear-gradient(135deg, ${C.gold}, ${C.crimson})`,
          border:"none", color: aiLoading ? C.muted : "#000",
          fontSize:13, fontWeight:800, cursor: aiLoading ? "default" : "pointer",
          letterSpacing:0.5,
        }}>
          {aiLoading ? "Generando mensaje..." : "⚡ Generar motivación con IA"}
        </button>
      </div>

      {/* Stats */}
      {[
        { label:"Bloques completados", val:completedBlocks.length, total:BLOCKS.length, icon:"◎", color:C.gold },
        { label:"Pasos SaaS listos",   val:completedSteps.length,  total:STEPS.length,  icon:"◈", color:C.crimson },
        { label:"Puntos acumulados",   val:points,                  total:totalPts,      icon:"⭐", color:C.green },
      ].map((s,i) => (
        <div key={i} style={{ background:C.surface, border:`1px solid ${C.border}`, borderRadius:14, padding:"13px 16px", marginBottom:8, display:"flex", alignItems:"center", gap:12 }}>
